<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingVertical="8dp"
    android:paddingHorizontal="16dp">

    <!-- Сообщение пользователя (справа) -->
    <LinearLayout
        android:id="@+id/user_message_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:visibility="gone">

        <!-- Временная метка -->
        <TextView
            android:id="@+id/user_message_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="12:00"
            android:textColor="@color/text_hint"
            android:textSize="11sp"
            android:layout_gravity="center_vertical"
            android:layout_marginEnd="12dp" />

        <!-- Контейнер сообщения -->
        <androidx.cardview.widget.CardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/user_message_bg"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardMaxElevation="0dp"
            app:contentPadding="16dp">

            <TextView
                android:id="@+id/user_message_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Тестовое сообщение пользователя"
                android:textColor="@color/user_message_text"
                android:textSize="15sp"
                android:lineSpacingExtra="2sp" />

        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- Сообщение бота (слева) -->
    <LinearLayout
        android:id="@+id/bot_message_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="start"
        android:visibility="gone">

        <!-- Контейнер сообщения -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/bot_message_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Тестовое сообщение бота"
                android:textColor="@color/bot_message_text"
                android:textSize="15sp"
                android:lineSpacingExtra="2sp"
                android:padding="16dp"
                android:background="@drawable/bot_message_dg" />

            <!-- Временная метка -->
            <TextView
                android:id="@+id/bot_message_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12:00"
                android:textColor="@color/text_hint"
                android:textSize="11sp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="4dp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>